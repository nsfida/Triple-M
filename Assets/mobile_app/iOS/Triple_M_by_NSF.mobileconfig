<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ══ Profile Metadata ══ -->
    <key>PayloadType</key>
    <string>Configuration</string>

    <key>PayloadVersion</key>
    <integer>1</integer>

    <key>PayloadDisplayName</key>
    <string>Triple M by NSF</string>

    <key>PayloadDescription</key>
    <string>Installs the Triple M by NSF app on your Home Screen as a full-screen web app.</string>

    <key>PayloadIdentifier</key>
    <string>com.webclip.Triple M by NSF.profile</string>

    <key>PayloadUUID</key>
    <string>EC08E74B-A0DC-4615-92F7-9D09D62D5342</string>

    <key>PayloadOrganization</key>
    <string>Triple M by NSF</string>

    <key>PayloadRemovalDisallowed</key>
    <false/>

    <!-- ══ Web Clip Payload ══ -->
    <key>PayloadContent</key>
    <array>
        <dict>

            <key>PayloadType</key>
            <string>com.apple.webClip.managed</string>

            <key>PayloadVersion</key>
            <integer>1</integer>

            <key>PayloadIdentifier</key>
            <string>com.webclip.Triple M by NSF</string>

            <key>PayloadUUID</key>
            <string>140FC9F1-7112-45EE-85E1-CB561B4328BB</string>

            <key>PayloadDisplayName</key>
            <string>Triple M by NSF</string>

            <key>PayloadDescription</key>
            <string>Triple M by NSF</string>

            <!-- URL that opens when the icon is tapped -->
            <key>URL</key>
            <string>https://triplem.vip</string>

            <!-- Label shown under the icon on the Home Screen -->
            <key>Label</key>
            <string>Triple M by NSF</string>

            <!-- Hides Safari address bar — true app experience -->
            <key>FullScreen</key>
            <true/>

            <!-- Use icon as-is, no iOS gloss overlay -->
            <key>Precomposed</key>
            <true/>

            <!-- User can remove from Home Screen -->
            <key>IsRemovable</key>
            <true/>

            <!-- Embedded app icon (base64 PNG, 180x180, from logo.ico) -->
            <key>Icon</key>
            <data>

            </data>

        </dict>
    </array>

</dict>
</plist>
